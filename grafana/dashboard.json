{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "${dashboard_uid}"
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "query": {
            "kind": "DataQuery",
            "group": "grafana",
            "version": "v0",
            "datasource": {
              "name": "-- Grafana --"
            },
            "spec": {}
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "builtIn": true
        }
      },
      {
        "kind": "AnnotationQuery",
        "spec": {
          "query": {
            "kind": "DataQuery",
            "group": "loki",
            "version": "v0",
            "datasource": {
              "name": "grafanacloud-logs"
            },
            "spec": {
              "expr": "",
              "interval": "",
              "refId": "Anno"
            }
          },
          "enable": true,
          "hide": true,
          "iconColor": "blue",
          "name": "Workflow changes",
          "legacyOptions": {
            "expr": "{service_name=\"workflow-observability\"} | event=\"workflow_changed\" | repo=\"${repo}\" | workflow_file=\".github/workflows/${workflow_file}\" | keep workflow_file,html_url",
            "queryType": "range",
            "textFormat": "<a href=\"{{html_url}}\" target=\"_blank\">Changes to {{workflow_file}}</a>",
            "titleFormat": "Workflow changed"
          }
        }
      }
    ],
    "cursorSync": "Off",
    "description": "Scheduled workflow run frequency, duration, and change tracking",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Last run started",
          "description": "Time when the last scheduled run was created",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
                      },
                      "spec": {
                        "direction": "forward",
                        "editorMode": "code",
                        "expr": "last_over_time({service_name=\"workflow-observability\"} | event=\"workflow_run_created\" | repo=\"${repo}\" | workflow=\"${workflow}\" | trigger=\"schedule\" | label_format elapsed=`{{ sub (unixEpoch now) (unixEpoch __timestamp__) }}` | unwrap elapsed [$__range]) by ()",
                        "queryType": "range"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "13.1.0-25254801320",
            "spec": {
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "percentChangeColorMode": "standard",
                "reduceOptions": {
                  "calcs": ["lastNotNull"],
                  "fields": "",
                  "values": false
                },
                "showPercentChange": false,
                "text": {
                  "valueSize": 72
                },
                "textMode": "value",
                "wideLayout": true
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "s",
                  "decimals": 1,
                  "thresholds": {
                    "mode": "absolute",
                    "steps": "__LAST_RUN_STARTED_THRESHOLDS__"
                  },
                  "color": {
                    "mode": "thresholds"
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Run frequency",
          "description": "Scheduled runs created over time",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
                      },
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "count_over_time({service_name=\"workflow-observability\"} | event=\"workflow_run_created\" | repo=\"${repo}\" | workflow=\"${workflow}\" | trigger=\"schedule\" [$__interval])",
                        "queryType": "range"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "13.1.0-25254801320",
            "spec": {
              "options": {
                "annotations": {
                  "clustering": -1,
                  "multiLane": false
                },
                "legend": {
                  "calcs": [],
                  "displayMode": "list",
                  "placement": "bottom",
                  "showLegend": false
                },
                "tooltip": {
                  "hideZeros": false,
                  "mode": "single",
                  "sort": "none"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "decimals": 0,
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "green"
                      },
                      {
                        "value": 80,
                        "color": "red"
                      }
                    ]
                  },
                  "color": {
                    "mode": "continuous-GrYlRd",
                    "seriesBy": "last"
                  },
                  "custom": {
                    "axisBorderShow": false,
                    "axisCenteredZero": false,
                    "axisColorMode": "text",
                    "axisLabel": "",
                    "axisPlacement": "right",
                    "barAlignment": 0,
                    "barWidthFactor": 1,
                    "drawStyle": "bars",
                    "fillOpacity": 70,
                    "gradientMode": "scheme",
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    },
                    "insertNulls": false,
                    "lineInterpolation": "linear",
                    "lineStyle": {
                      "fill": "solid"
                    },
                    "lineWidth": 1,
                    "pointSize": 5,
                    "scaleDistribution": {
                      "type": "linear"
                    },
                    "showPoints": "auto",
                    "showValues": false,
                    "spanNulls": false,
                    "stacking": {
                      "group": "A",
                      "mode": "none"
                    },
                    "thresholdsStyle": {
                      "mode": "off"
                    }
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Run duration",
          "description": "Duration of each completed scheduled run in seconds",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
                      },
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "last_over_time({service_name=\"workflow-observability\"} | event=\"workflow_run_completed\" | repo=\"${repo}\" | workflow=\"${workflow}\" | trigger=\"schedule\" | unwrap duration_seconds [$__interval])",
                        "queryType": "range"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "13.1.0-25254801320",
            "spec": {
              "options": {
                "annotations": {
                  "clustering": -1,
                  "multiLane": false
                },
                "legend": {
                  "calcs": [],
                  "displayMode": "list",
                  "placement": "bottom",
                  "showLegend": false
                },
                "tooltip": {
                  "hideZeros": false,
                  "mode": "single",
                  "sort": "none"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "s",
                  "decimals": 0,
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "green"
                      },
                      {
                        "value": 80,
                        "color": "red"
                      }
                    ]
                  },
                  "color": {
                    "mode": "continuous-GrYlRd",
                    "seriesBy": "last"
                  },
                  "custom": {
                    "axisBorderShow": false,
                    "axisCenteredZero": false,
                    "axisColorMode": "text",
                    "axisLabel": "",
                    "axisPlacement": "right",
                    "barAlignment": 0,
                    "barWidthFactor": 1,
                    "drawStyle": "bars",
                    "fillOpacity": 70,
                    "gradientMode": "scheme",
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    },
                    "insertNulls": false,
                    "lineInterpolation": "linear",
                    "lineStyle": {
                      "fill": "solid"
                    },
                    "lineWidth": 1,
                    "pointSize": 5,
                    "scaleDistribution": {
                      "type": "linear"
                    },
                    "showPoints": "auto",
                    "showValues": false,
                    "spanNulls": false,
                    "stacking": {
                      "group": "A",
                      "mode": "none"
                    },
                    "thresholdsStyle": {
                      "mode": "off"
                    }
                  }
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "Recent runs",
          "description": "Log entries for scheduled workflow run events",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
                      },
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "{service_name=\"workflow-observability\"} | repo=\"${repo}\" | workflow=\"${workflow}\" | trigger=\"schedule\"",
                        "queryType": "range"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [
                {
                  "kind": "Transformation",
                  "group": "extractFields",
                  "spec": {
                    "options": {
                      "delimiter": ",",
                      "format": "json",
                      "keepTime": true,
                      "replace": true,
                      "source": "labels"
                    }
                  }
                },
                {
                  "kind": "Transformation",
                  "group": "organize",
                  "spec": {
                    "options": {
                      "excludeByName": {
                        "detected_level": true,
                        "org": true,
                        "repo": true,
                        "service_name": true,
                        "severity_number": true,
                        "severity_text": true,
                        "trigger": true,
                        "workflow": true
                      },
                      "includeByName": {},
                      "indexByName": {
                        "Time": 0,
                        "conclusion": 2,
                        "detected_level": 5,
                        "duration_seconds": 3,
                        "event": 1,
                        "html_url": 4,
                        "org": 6,
                        "repo": 7,
                        "service_name": 8,
                        "severity_number": 9,
                        "severity_text": 10,
                        "trigger": 11,
                        "workflow": 12
                      },
                      "renameByName": {
                        "conclusion": "Conclusion",
                        "duration_seconds": "Duration",
                        "event": "Event",
                        "html_url": "Link"
                      }
                    }
                  }
                }
              ],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "table",
            "version": "13.1.0-25254801320",
            "spec": {
              "options": {
                "cellHeight": "sm",
                "showHeader": true,
                "sortBy": [
                  {
                    "desc": true,
                    "displayName": "Time"
                  }
                ]
              },
              "fieldConfig": {
                "defaults": {
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "green"
                      },
                      {
                        "value": 80,
                        "color": "red"
                      }
                    ]
                  },
                  "color": {
                    "mode": "thresholds"
                  },
                  "custom": {
                    "align": "auto",
                    "cellOptions": {
                      "type": "auto"
                    },
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "Time"
                    },
                    "properties": [
                      {
                        "id": "custom.width",
                        "value": 150
                      },
                      {
                        "id": "unit",
                        "value": "dateTimeFromNow"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "Event"
                    },
                    "properties": [
                      {
                        "id": "custom.width",
                        "value": 200
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "Conclusion"
                    },
                    "properties": [
                      {
                        "id": "custom.width",
                        "value": 100
                      },
                      {
                        "id": "custom.cellOptions",
                        "value": {
                          "type": "pill"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "Duration"
                    },
                    "properties": [
                      {
                        "id": "custom.width",
                        "value": 100
                      },
                      {
                        "id": "unit",
                        "value": "s"
                      },
                      {
                        "id": "decimals",
                        "value": 1
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byName",
                      "scope": "series",
                      "options": "Link"
                    },
                    "properties": [
                      {
                        "id": "links",
                        "value": [
                          {
                            "targetBlank": true,
                            "title": "View on GitHub",
                            "url": "$${__value.text}"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      },
      "panel-5": {
        "kind": "Panel",
        "spec": {
          "id": 5,
          "title": "Run health",
          "description": "Whether scheduled runs are arriving within the expected intervals",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
                      },
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "sum(count_over_time({service_name=\"workflow-observability\"} | event=\"workflow_run_created\" | repo=\"${repo}\" | workflow=\"${workflow}\" | trigger=\"schedule\" [__WARNING_THRESHOLD_SECONDS__s]))",
                        "queryType": "range",
                        "legendFormat": "warning"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "grafanacloud-logs"
                      },
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "sum(count_over_time({service_name=\"workflow-observability\"} | event=\"workflow_run_created\" | repo=\"${repo}\" | workflow=\"${workflow}\" | trigger=\"schedule\" [__CRITICAL_THRESHOLD_SECONDS__s]))",
                        "queryType": "range",
                        "legendFormat": "critical"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "state-timeline",
            "version": "13.1.0-25254801320",
            "spec": {
              "options": {
                "showValue": "auto",
                "mergeValues": true,
                "alignValue": "left",
                "legend": {
                  "displayMode": "hidden",
                  "placement": "bottom",
                  "showLegend": false
                },
                "tooltip": {
                  "mode": "single",
                  "sort": "none"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "value": 0,
                        "color": "red"
                      },
                      {
                        "value": 1,
                        "color": "green"
                      }
                    ]
                  },
                  "color": {
                    "mode": "thresholds"
                  },
                  "mappings": [
                    {
                      "type": "value",
                      "options": {
                        "0": {
                          "text": "Missing",
                          "color": "red"
                        }
                      }
                    },
                    {
                      "type": "range",
                      "options": {
                        "from": 1,
                        "to": 999999,
                        "result": {
                          "text": "Healthy",
                          "color": "green"
                        }
                      }
                    }
                  ],
                  "custom": {
                    "fillOpacity": 80,
                    "lineWidth": 0
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byName",
                      "options": "warning"
                    },
                    "properties": [
                      {
                        "id": "mappings",
                        "value": [
                          {
                            "type": "value",
                            "options": {
                              "0": {
                                "text": "Delayed",
                                "color": "#EAB839"
                              }
                            }
                          },
                          {
                            "type": "range",
                            "options": {
                              "from": 1,
                              "to": 999999,
                              "result": {
                                "text": "Healthy",
                                "color": "green"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          {
            "kind": "GridLayoutItem",
            "spec": {
              "x": 0,
              "y": 0,
              "width": 9,
              "height": 8,
              "element": {
                "kind": "ElementReference",
                "name": "panel-2"
              }
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "x": 9,
              "y": 0,
              "width": 9,
              "height": 8,
              "element": {
                "kind": "ElementReference",
                "name": "panel-3"
              }
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "x": 18,
              "y": 0,
              "width": 6,
              "height": 8,
              "element": {
                "kind": "ElementReference",
                "name": "panel-1"
              }
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "x": 0,
              "y": 8,
              "width": 24,
              "height": 4,
              "element": {
                "kind": "ElementReference",
                "name": "panel-5"
              }
            }
          },
          {
            "kind": "GridLayoutItem",
            "spec": {
              "x": 0,
              "y": 12,
              "width": 24,
              "height": 10,
              "element": {
                "kind": "ElementReference",
                "name": "panel-4"
              }
            }
          }
        ]
      }
    },
    "links": [],
    "liveNow": false,
    "preload": false,
    "tags": [],
    "timeSettings": {
      "from": "now-24h",
      "to": "now",
      "autoRefresh": "5m",
      "autoRefreshIntervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ],
      "hideTimepicker": false,
      "fiscalYearStartMonth": 0
    },
    "title": "${title}",
    "variables": [],
    "preferences": {
      "layout": {
        "kind": "AutoGridLayout",
        "spec": {
          "maxColumnCount": 3,
          "columnWidthMode": "standard",
          "rowHeightMode": "standard",
          "items": []
        }
      }
    }
  }
}
